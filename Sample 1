import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from scipy.stats import ttest_ind
from sklearn.model_selection import train_test_split
from sklearn.ensemble import RandomForestRegressor, RandomForestClassifier
from sklearn.metrics import mean_absolute_error, accuracy_score
import os

# Create visuals folder
os.makedirs('visuals', exist_ok=True)

np.random.seed(42)
n = 10000

# ====================== DATA GENERATION ======================
models = ['gpt-3.5-turbo', 'gpt-4', 'gpt-4o']
prompt_types = ['Creative', 'Factual', 'Coding', 'Reasoning', 'General']

data = {
    'Model': np.random.choice(models, n, p=[0.35, 0.25, 0.40]),
    'Prompt_Type': np.random.choice(prompt_types, n),
    'Satisfaction_Score': np.clip(np.random.normal(4.3, 0.75, n), 1.0, 5.0),
    'Hallucination_Flag': np.random.choice([0, 1], n, p=[0.926, 0.074]),
    'Tokens_Used': np.random.lognormal(6.05, 0.65, n).astype(int).clip(50, 2000),
    'Is_Structured_Prompt': np.random.choice([0, 1], n, p=[0.65, 0.35]),
    'Latency_ms': np.random.lognormal(4.8, 0.9, n).astype(int).clip(120, 4500),
}

df = pd.DataFrame(data)

print("=== OPENAI MODEL OUTPUT QUALITY ANALYSIS ===")
print(f"Total Interactions Analyzed : {len(df):,}")
print(f"Average Satisfaction Score  : {df['Satisfaction_Score'].mean():.2f}/5.0")
print(f"Overall Hallucination Rate  : {(df['Hallucination_Flag'].mean()*100):.1f}%")
print(f"Average Tokens per Response : {df['Tokens_Used'].mean():.0f}\n")

# ====================== EDA & STATISTICS ======================
print("Performance by Model:")
print(df.groupby('Model').agg({
    'Satisfaction_Score': 'mean',
    'Hallucination_Flag': 'mean',
    'Tokens_Used': 'mean'
}).round(3))

# Statistical Test
structured = df[df['Is_Structured_Prompt'] == 1]['Satisfaction_Score']
normal = df[df['Is_Structured_Prompt'] == 0]['Satisfaction_Score']
_, p_val = ttest_ind(structured, normal)
print(f"\nStructured Prompt Improvement p-value: {p_val:.6f}\n")

