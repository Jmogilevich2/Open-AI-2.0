# 3. Structured Prompt Impact
plt.figure()
sns.boxplot(x='Is_Structured_Prompt', y='Satisfaction_Score', data=df, palette=['#FF6F00', '#10A37F'])
plt.title('Impact of Structured Prompts on User Satisfaction')
plt.xlabel('Structured Prompt (0 = No, 1 = Yes)')
plt.savefig('visuals/structured_prompt_impact.png', dpi=300, bbox_inches='tight')
plt.close()

# 4. Satisfaction by Prompt Type
plt.figure()
sns.boxplot(x='Prompt_Type', y='Satisfaction_Score', data=df, palette='viridis')
plt.title('Satisfaction Score by Prompt Type')
plt.xticks(rotation=45)
plt.savefig('visuals/prompt_type_satisfaction.png', dpi=300, bbox_inches='tight')
plt.close()

print("✅ All visualizations saved in 'visuals/' folder\n")

